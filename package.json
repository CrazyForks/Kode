{
  "name": "@shareai-lab/kode",
  "version": "2.2.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "kode": "cli.js",
    "kwa": "cli.js",
    "kd": "cli.js",
    "mcp-cli": "mcp-cli.js",
    "kode-acp": "cli-acp.js"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "main": "cli.js",
  "exports": {
    ".": {
      "require": "./cli.js",
      "default": "./cli.js"
    },
    "./protocol": {
      "import": "./dist/sdk/protocol.js",
      "require": "./dist/sdk/protocol.cjs"
    },
    "./client": {
      "import": "./dist/sdk/client.js",
      "require": "./dist/sdk/client.cjs"
    },
    "./daemon-client": {
      "import": "./dist/sdk/daemon-client.js",
      "require": "./dist/sdk/daemon-client.cjs"
    },
    "./core": {
      "import": "./dist/sdk/core.js",
      "require": "./dist/sdk/core.cjs"
    },
    "./tools": {
      "import": "./dist/sdk/tools.js",
      "require": "./dist/sdk/tools.cjs"
    },
    "./runtime": {
      "import": "./dist/sdk/runtime.js",
      "require": "./dist/sdk/runtime.cjs"
    },
    "./runtime-node": {
      "import": "./dist/sdk/runtime-node.js",
      "require": "./dist/sdk/runtime-node.cjs"
    }
  },
  "author": "ShareAI-lab <ai-lab@foxmail.com>",
  "license": "Apache-2.0",
  "description": "AI-powered terminal assistant that understands your codebase, edits files, runs commands, and automates development workflows.",
  "homepage": "https://github.com/shareAI-lab/kode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shareAI-lab/kode.git"
  },
  "bugs": {
    "url": "https://github.com/shareAI-lab/kode/issues"
  },
  "files": [
    "cli.js",
    "cli-acp.js",
    "mcp-cli.js",
    "yoga.wasm",
    "dist/**/*",
    "!dist/bin/**",
    "!dist/binary/**",
    "packages/builtin-skills/THIRD_PARTY_NOTICES.md",
    "packages/builtin-skills/skills/**/*",
    "packages/builtin-skills/third_party/shareai-skills/LICENSE",
    "scripts/cli-wrapper.cjs",
    "scripts/cli-acp-wrapper.cjs",
    "scripts/binary-utils.cjs",
    "scripts/postinstall.js",
    ".npmrc"
  ],
  "scripts": {
    "dev": "bun run ./apps/cli/src/dispatch.ts --verbose",
    "dev:cli": "bun run ./apps/cli/src/dispatch.ts --verbose",
    "dev:server": "bun run --filter @kode/server dev",
    "dev:web": "bun run --filter @kode/web dev",
    "dev:bun": "bun run ./apps/cli/src/dispatch.ts --verbose",
    "build:cli": "node scripts/build-cli.mjs",
    "build:server": "node scripts/build-server.mjs",
    "build:web": "node scripts/build-web.mjs",
    "build": "bun run build:npm",
    "build:binary": "bun run scripts/build-binary.mjs",
    "clean": "bun run scripts/clean.mjs",
    "prepublishOnly": "bun run build:npm && bun run scripts/prepublish-check.js",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,md,css,html}\" \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,json}\" \"docs/**/*.{md,json}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,md,css,html}\" \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,json}\" \"docs/**/*.{md,json}\"",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run typecheck && bun test && bun run build",
    "prepare": "node scripts/install-hooks.mjs",
    "publish:dev": "bun run scripts/publish-dev.js",
    "publish:release": "bun run scripts/publish-release.js",
    "bench:startup": "bun run scripts/bench-startup.mjs",
    "build:npm": "bun run scripts/build.mjs",
    "postinstall": "node scripts/postinstall.js || true",
    "test:unit": "bun test packages/core/src/test/unit apps/cli/src/**/*.test.ts apps/cli/src/**/*.test.tsx packages/*/src/test/unit",
    "test:integration": "bun test packages/core/src/test/integration",
    "test:e2e": "bun test packages/core/src/test/e2e",
    "parity:reference": "bun run scripts/reference-parity-check.mjs"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.30.1",
    "@anthropic-ai/sdk": "^0.102.0",
    "@anthropic-ai/vertex-sdk": "^0.17.0",
    "@aws-sdk/client-bedrock-runtime": "3.1063.0",
    "@commander-js/extra-typings": "^13.1.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.17",
    "ajv": "^8.20.0",
    "ansi-escapes": "^7.3.0",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "debug": "^4.4.1",
    "diff": "^9.0.0",
    "dotenv": "^16.6.1",
    "env-paths": "^3.0.0",
    "fflate": "^0.8.3",
    "figures": "^6.1.0",
    "glob": "^11.0.3",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "ignore": "^7.0.5",
    "ink": "6.6.0",
    "ink-link": "^4.1.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.2.0",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.5.1",
    "marked": "^15.0.12",
    "minimatch": "^10.2.5",
    "nanoid": "^5.1.11",
    "node-fetch": "^3.3.2",
    "node-html-parser": "^7.1.0",
    "openai": "^4.104.0",
    "react": "19.2.3",
    "react-reconciler": "^0.33.0",
    "semver": "^7.8.2",
    "shell-quote": "^1.8.4",
    "spawn-rx": "^5.1.2",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.2.0",
    "tsx": "^4.22.4",
    "turndown": "^7.2.4",
    "undici": "^7.27.2",
    "which": "^6.0.0",
    "wrap-ansi": "^9.0.0",
    "ws": "^8.18.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2",
    "sharp": "^0.34.5"
  },
  "optionalDependencies": {
    "@vscode/ripgrep": "^1.18.0"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.10",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@eslint/js": "9.39.4",
    "@types/bun": "^1.3.14",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.1",
    "@types/which": "^3.0.4",
    "@uiw/react-codemirror": "^4.24.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.4.21",
    "bun-types": "^1.3.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.25.12",
    "lucide-react": "^0.542.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "prettier": "3.8.3",
    "react-devtools-core": "^7.0.1",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.5",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1"
  },
  "overrides": {
    "@aws-sdk/client-bedrock-runtime": "3.1063.0",
    "ws": "8.21.0"
  }
}
